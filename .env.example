# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_replace_me

# Public site URL (recommended for canonical tags, OG, robots and sitemap)
NEXT_PUBLIC_SITE_URL=https://rentyco.app

# Cloudflare R2 (required for image storage)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=renty-listing-images
R2_PUBLIC_URL=https://pub-xxx.r2.dev
